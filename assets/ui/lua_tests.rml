<rml>
<head>
    <link type="text/rcss" href="../rmlui/rml.rcss"/>
    <link type="text/rcss" href="UGECore.rcss"/>
    <link type="text/rcss" href="navButton.rcss"/>
    <style>
    /* ── Coin window ──────────────────────────────────────────── */
    .coin-window {
        position: relative;
        width: 100px;
        height: 100px;
        background-color: transparent;
    }

    /* ── Demo table ───────────────────────────────────────────── */
    .tick-table {
        display: table;
        position: absolute;
        top: 780px;
        width: 100%;
        background-color: #1e1e2e99;
        color: #cdd6f4;
        font-family: LatoLatin;
        font-size: 22px;
    }

    .tick-table tr {
        display: table-row;
    }

    .tick-table td {
        display: table-cell;
        padding: 16px;
        vertical-align: middle;
    }

    /* Column widths */
    .tick-table .col-left   { width: 150px; }
    .tick-table .col-center { width: 1300px; }
    .tick-table .col-right  { width: 150px; }

    /* Border only on the center cell of the middle row */
    .tick-table .col-center.bordered {
        border: 3px #89b4fa;
        border-radius: 8px;
    }

    /* ── Radio option buttons ────────────────────────────────────────── */
    .radio-group {
        display: inline-block;
        margin-top: 12px;
    }

    .radio-option {
        display: inline-block;
        cursor: pointer;
        padding: 8px 24px;
        font-size: 22px;
        font-weight: bold;
        color: #cdd6f4;
        background-color: #313244;
        border: 2px #4a4a6a;
    }

    .radio-option:first-child {
        border-radius: 16px 0px 0px 16px;
    }

    .radio-option:last-child {
        border-radius: 0px 16px 16px 0px;
    }

    .radio-option:hover {
        background-color: #45475a;
    }

    .radio-option input {
        margin-right: 6px;
    }

    /* ── Checkbox ───────────────────────────────────────────────── */
    input.checkbox {
        width: 24px;
        height: 24px;
        background-color: #313244;
        border: 2px #89b4fa;
        border-radius: 4px;
    }

    input.checkbox:hover {
        background-color: #45475a;
    }

    input.checkbox:checked {
        background-color: #89b4fa;
        image-color: #1e1e2e;
    }

    input.copyable {
        display: block;
        background-color: transparent;
        color: #cdd6f4;
        border: 2px;
        font-size: 1em;
        font-style: italic;
        width: 100%;
        margin: 0px;
        padding: 0px;
        box-sizing: border-box;
        text-align: left;
    }

    /* ── Notes table ─────────────────────────────────────────────── */
    .notes-table {
        display: table;
        position: absolute;
        top: 300px;
        width: auto;
        background-color: #1e1e2e99;
        color: #cdd6f4;
        font-family: LatoLatin;
        font-size: 22px;
    }

    .notes-table tr {
        display: table-row;
        text-align: right;
    }

    .notes-table td {
        display: table-cell;
        padding: 16px;
        vertical-align: middle;
    }

    .notes-table .col-notes { width: 500px; }
    .notes-table .col-cmd   { width: 600px; }

    .notes-table .header-row td {
        background-color: #313244;
        font-weight: bold;
        font-size: 26px;
        color: #89b4fa;
        text-align: center;
        border-bottom: 3px #4a4a6a;
    }

    </style>
</head>
<body data-model="lua-tests">

    <div id="lua-console" data-fragment="assets/ui/frag_luaConsole.rml"/>

    <!-- Nav button back -->
    <div class="nav-button-back">
        <span class="nav-button-arrow" data-event-click="onPrevious"><img src="../ui/LeftArrow.png" style="margin-top:10px;width:50px;height:auto;"/></span>
        <span class="nav-button-label">Previous</span>
    </div>

    <!-- Nav button next -->
    <div class="nav-button">
        <span class="nav-button-arrow" data-event-click="onNext"><img src="../ui/RightArrow.png" style="margin-top:10px;width:50px;height:auto;"/></span>
        <span class="nav-button-label">Next</span>
    </div>




    <!-- Page title -->
    <div style="position: absolute; top: 20px; left: 450px; width:800px; font-size: 80px; font-weight: bold;text-align:center; color: #cdd6f4; font-family: LatoLatin;">Lua Control Demos
    <br/><span style="font-size: 36px; color: #89b4fa;">Press ~ to access Lua console</span>
    </div>

    <table class="notes-table">
        <tr class="header-row">
            <td class="col-notes">Notes</td>
            <td class="col-cmd">Console Command</td>
        </tr>
        <tr>
            <td class="col-notes">Switch scene!</td>
            <td class="col-cmd"><input class="copyable" type="text" readonly="readonly" value="SDL.LoadScene('platformer')"/></td>
        </tr>
        <tr>
            <td class="col-notes">From platformer: play with physics<br/>LUA->Game State->Game c++</td>
            <td class="col-cmd"><input class="copyable" type="text" readonly="readonly" value="Data.SetTransient('plat2d.physics.gravity', 10)"/></td>
        </tr>
        <tr>
            <td class="col-notes">From platformer: Trigger game actions<br/>Lua->Game c++</td>
            <td class="col-cmd"><input class="copyable" type="text" readonly="readonly" value="plat2d.Jump()"/></td>
        </tr>
        <tr>
            <td class="col-notes">From platformer: Cheat your score<br/>Lua->Game State->UI</td>
            <td class="col-cmd"><input class="copyable" type="text" readonly="readonly" value="Data.SetTransient('plat2d.Score', 100)"/></td>
        </tr>
        <tr>
            <td class="col-notes">From platformer: Break the system?</td>
            <td class="col-cmd"><input class="copyable" type="text" readonly="readonly" value="Data.SetTransient('plat2d.Score', 'Not an integer')"/></td>
        </tr>
    </table>

    <table class="notes-table" style="left:1110px;">
        <tr class="header-row">
            <td class="col-notes">Misc Cmds</td>
        </tr>
        <tr>
            <td class="col-cmd"><input class="copyable" type="text" readonly="readonly" value="Data.ShowTransient()"/></td>
        </tr>
        <tr>
            <td class="col-cmd"><input class="copyable" type="text" readonly="readonly" value="UGE.ShowTicking()"/></td>
        </tr>
        <tr>
            <td class="col-cmd"><input class="copyable" type="text" readonly="readonly" value="SDL.ShowCollision()"/></td>
        </tr>


    </table>

    <table class="tick-table">
         <tr>
            <td class="col-left"></td>
            <td class="col-center" style="text-align: center;">LUA Tick Test</td>
            <td class="col-right"></td>
        </tr>
        <tr>
            <td class="col-left">

            </td>
            <td class="col-center">
                <table style="background-color: transparent; color: white;">
                         <tr style="text-align: center;">
                            <td><button class="submit-btn"
                                                        style="background-color: #f38ba8;
                                                               color: #1e1e2e;
                                                               border: 3px #c0637a;
                                                               border-radius: 16px;
                                                               padding: 10px 32px;
                                                               font-size: 24px;
                                                               font-weight: bold;
                                                               cursor: pointer;"
                                                        data-event-click="onHardStop">Hard Stop</button></td>
                            <td>
                            <button class="submit-btn"
                                    style="background-color: #89b4fa;
                                           color: #1e1e2e;
                                           border: 3px #4a6fa5;
                                           border-radius: 16px;
                                           padding: 10px 32px;
                                           font-size: 24px;
                                           font-weight: bold;
                                           cursor: pointer;"
                                    data-event-click="onStartTick">Start LUA Tick</button>
                            <div class="radio-group">
                            <label class="radio-option"
                                   data-style-background-color="coin_direction == '-1' ? '#89b4fa' : '#313244'"
                                   data-style-color="coin_direction == '-1' ? '#1e1e2e' : '#cdd6f4'">
                                <input type="radio" name="coin_dir"
                                           data-attrif-checked="coin_direction == '-1'"
                                           data-event-change="onSelectLeft"/>Left
                                </label>
                                <label class="radio-option"
                                       data-style-background-color="coin_direction == '1' ? '#89b4fa' : '#313244'"
                                       data-style-color="coin_direction == '1' ? '#1e1e2e' : '#cdd6f4'">
                                    <input type="radio" name="coin_dir" checked
                                           data-attrif-checked="coin_direction == '1'"
                                           data-event-change="onSelectRight"/>Right
                                </label>
                            </div>
                            </td>
                            <td style="text-align: left; padding-left: 24px;">
                                <label style="display: inline-block; cursor: pointer;
                                              color: #cdd6f4; font-size: 22px; font-weight: bold;">
                                    <input type="checkbox"
                                           data-attrif-checked="state_stop == 1"
                                           data-event-change="onStateStopChange"
                                           style="margin-right: 10px; width: 24px; height: 24px;
                                                  vertical-align: middle;"/>
                                    Stateful Stop
                                </label>
                            </td>
                        </tr>
                </table>
            </td>
            <td class="col-right"></td>
        </tr>
        <tr>
            <td class="col-left"></td>
            <td class="col-center bordered">
                <div class="coin-window" data-style-left="coin_left + 'px'" data-style-top="coin_top + 'px'">
                                                    <img src="../Sprites/Coin.png" style="width:100px;height:100px;" />
                </div
            ></td>
            <td class="col-right"></td>
        </tr>
        <tr>
            <td class="col-left"></td>
            <td class="col-center" style="text-align:center;"><b>Initiates a LUA function that will tick until a stop state is reached.</b></td>
            <td class="col-right"></td>
        </tr>
    </table>




</body>
</rml>